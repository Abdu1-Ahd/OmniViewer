# OmniViewer .gitattributes
# Normalize line endings: store LF in repo, checkout CRLF on Windows

* text=auto eol=lf

# Force LF for these file types regardless of OS
*.ts    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.txt   text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.vsix  binary
*.wasm  binary
*.zip   binary
*.tar   binary
*.7z    binary
